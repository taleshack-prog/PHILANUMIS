# Privy — https://dashboard.privy.io (crie um app, cole o App ID aqui)
NEXT_PUBLIC_PRIVY_APP_ID=

# RPC da Base (mainnet e Sepolia)
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Rede ativa: "base" ou "baseSepolia"
NEXT_PUBLIC_ACTIVE_NETWORK=baseSepolia

# Endereços dos contratos — preencher após cada deploy (ver PHILANUMIS/scripts/deploy.js)
NEXT_PUBLIC_CORE_ADDRESS=
NEXT_PUBLIC_LIQUIDITY_VAULT_ADDRESS=
NEXT_PUBLIC_FIXED_PRICE_SALE_ADDRESS=
NEXT_PUBLIC_REDEMPTION_VAULT_ADDRESS=
NEXT_PUBLIC_CUSTODY_ORACLE_ADDRESS=
NEXT_PUBLIC_QUEST_ENGINE_ADDRESS=
# USDC nativo — mainnet abaixo; para Base Sepolia troque pelo endereço do USDC de teste
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Pinata (upload de imagens/metadados pro IPFS) — https://app.pinata.cloud
# NUNCA prefixar com NEXT_PUBLIC_: essa chave roda só no servidor (ver src/app/api/upload/route.ts)
PINATA_JWT=
PINATA_GATEWAY=gateway.pinata.cloud
